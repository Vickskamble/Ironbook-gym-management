# Supabase credentials (REPLACE with your own)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here

# Razorpay Payment (REPLACE with your own Razorpay key ID)
# Get it from https://dashboard.razorpay.com → API Keys
RAZORPAY_KEY_ID=your_razorpay_key_id

# Razorpay Secret (for Supabase Edge Function)
# Set these in Supabase Dashboard → Edge Functions → handle-payment → Environment Variables
# RAZORPAY_KEY_SECRET=your_razorpay_key_secret